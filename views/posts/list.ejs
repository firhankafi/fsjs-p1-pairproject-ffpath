<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ffPath</title>
  <link rel="stylesheet" href="/css/list.css">
</head>
<body>
  <div class="page">
    <div class="header">
      <h1 class="title">ffPath 🧭</h1>

      <p class="welcome">Welcome, <strong><%= username %></strong> 🔥</p>

      <div class="top-actions">
        <a class="nav-link" href="/posts/add">Create Post</a> |
        <a class="nav-link" href="/logout">Logout</a>
      </div>

      <form class="search-form" method="GET" action="/posts">
        <input
          class="search-input"
          type="text"
          name="search"
          placeholder="Search title or hashtag..."
          value="<%= search %>"
        >
        <button class="search-btn" type="submit">Search</button>
      </form>

      <% if (msg) { %>
        <div class="message success"><%= msg %></div>
      <% } %>

      <% if (error) { %>
        <div class="message error"><%= error %></div>
      <% } %>
    </div>

    <% posts.forEach(post => { %>
      <div class="post-card" id="post-<%= post.id %>">

        <div class="user-row">
          <% if (post.User && post.User.Profile && post.User.Profile.displayAvatar) { %>
            <img
              class="avatar"
              src="<%= post.User.Profile.displayAvatar %>"
              width="50"
              height="50"
              alt="avatar"
            >
          <% } else { %>
            <div class="avatar-fallback">
              <%= post.User && post.User.username ? post.User.username[0].toUpperCase() : 'U' %>
            </div>
          <% } %>

          <div class="user-meta">
            <p class="posted-by">Posted by:</p>
            <p class="username">
              <%= post.User ? (post.User.username || post.User.email) : 'Unknown' %>
            </p>
            <% if (post.User && post.User.Profile && post.User.Profile.status) { %>
              <%= post.User.Profile.status %>
              <% } %>
          </div>
        </div>

        <h3 class="post-title"><%= post.title %></h3>

        <p class="post-content"><%= post.content %></p>

        <% if (post.imgUrl) { %>
          <img class="post-img" src="<%= post.imgUrl %>" width="250" alt="post image">
        <% } %>

        <p class="meta-line">📍 Location: <%= post.city %>, <%= post.country %></p>

        <p class="meta-line">❤️ Likes: <%= post.getLikeCount() %></p>

        <p class="meta-line">💬 Comments: <%= post.Comments ? post.Comments.length : 0 %></p>

        <% if (post.Tags && post.Tags.length) { %>
          <div class="tag-list">
            <% post.Tags.forEach(tag => { %>
              <span class="tag"><%= tag.name %></span>
            <% }) %>
          </div>
        <% } %>

        <%
          let isLiked = false
          if (post.Likes) {
            for (let like of post.Likes) {
              if (like.userId === userId) {
                isLiked = true
              }
            }
          }
        %>

        <div class="action-row">
          <% if (isLiked) { %>
            <a class="btn-link" href="/posts/<%= post.id %>/unlike">Unlike</a>
          <% } else { %>
            <a class="btn-link" href="/posts/<%= post.id %>/like">Like</a>
          <% } %>

          <a class="btn-link btn-outline" href="/posts/<%= post.id %>">Detail</a>

          <% if (post.userId === userId) { %>
            <a class="btn-link btn-outline" href="/posts/<%= post.id %>/edit">Edit</a>
          <% } %>

          <% if (post.userId === userId || role === 'admin') { %>
            <a class="btn-link btn-outline" href="/posts/<%= post.id %>/delete">Delete</a>
          <% } %>
        </div>

        <hr class="divider">
      </div>
    <% }) %>
  </div>
</body>
</html>